#!/bin/bash

mysql -e 'SELECT table_schema "DB Name", ROUND(SUM(data_length) / 1024 / 1024, 1) "Data Size, MB", ROUND(SUM(index_length) / 1024 / 1024, 1) "Index Size, MB", ROUND(SUM(data_length + index_length) / 1024 / 1024, 1) "DB Size, MB" FROM information_schema.tables GROUP BY table_schema ORDER BY `DB Size, MB` DESC;'
