#!/bin/bash

cd "$( dirname "${BASH_SOURCE[0]}" )"

# see /etc/fstab
mountpoint -q /mnt/gentoo || sudo mount /mnt/gentoo

mountpoint -q /mnt/gentoo/dev || sudo mount --rbind /dev /mnt/gentoo/dev
sudo mount --make-rslave /mnt/gentoo/dev
mountpoint -q /mnt/gentoo/proc || sudo mount -t proc /proc /mnt/gentoo/proc
mountpoint -q /mnt/gentoo/sys || sudo mount --rbind /sys /mnt/gentoo/sys
sudo mount --make-rslave /mnt/gentoo/sys

# better to have own to prevent collisions
# mountpoint -q /mnt/gentoo/tmp || sudo mount --rbind /tmp /mnt/gentoo/tmp
# D-Bus conflict
# mountpoint -q /mnt/gentoo/run || sudo mount --bind /run /mnt/gentoo/run

# should preverse guest files
mountpoint -q /mnt/gentoo/etc/resolv.conf || sudo mount --rbind /etc/resolv.conf /mnt/gentoo/etc/resolv.conf
mountpoint -q /mnt/gentoo/etc/hosts || sudo mount --rbind /etc/hosts /mnt/gentoo/etc/hosts

if [[ -z "$1" ]]; then
    sudo cp ../chroot-gentoo-profile /mnt/gentoo/etc/
    sudo chroot /mnt/gentoo /bin/bash --init-file /etc/chroot-gentoo-profile
else
    echo "export COLOR_SCHEME='$(~/.config/xsettingsd/get-color-scheme)'" | sudo tee "/mnt/gentoo/home/$1/.chroot-bashrc" > /dev/null
    echo "export debian_chroot='chroot artix'" | sudo tee -a "/mnt/gentoo/home/$1/.chroot-bashrc" > /dev/null
    cat ../chroot-gentoo-bashrc | sudo tee -a  "/mnt/gentoo/home/$1/.chroot-bashrc" > /dev/null

    # only if it hasn't own
    # sudo cp ~/.bashrc "/mnt/gentoo/home/$1/.host-bashrc"

    case "$2" in
    x11)
        # sudo xhost +local:
        sudo cp ../chroot-gentoo-x11-bashrc "/mnt/gentoo/home/$1/.chroot-x11-bashrc"
        sudo chroot /mnt/gentoo /usr/bin/sudo -H -i -u "$1" /bin/bash --init-file "/home/$1/.chroot-x11-bashrc"
        ;;
    *)
        sudo chroot /mnt/gentoo /usr/bin/sudo -H -i -u "$1" /bin/bash --init-file "/home/$1/.chroot-bashrc"
        ;;
    esac
fi
