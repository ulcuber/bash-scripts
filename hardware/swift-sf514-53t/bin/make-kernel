#!/bin/bash

KERNEL_PATH=/usr/src/linux

cd ${KERNEL_PATH}

COMMON_FLAGS="-O2 -pipe -march=native"
export CFLAGS="${COMMON_FLAGS}"
export CXXFLAGS="${COMMON_FLAGS}"
export RUSTFLAGS="${RUSTFLAGS} -C target-cpu=native"
export CPU_FLAGS_X86="aes avx avx2 f16c fma3 mmx mmxext pclmul popcnt rdrand sse sse2 sse3 sse4_1 sse4_2 ssse3 bmi1 bmi2"

make modules_prepare
make menuconfig

make -j4 || exit
emerge --quiet --verbose @module-rebuild || exit

# Having built both the kernel and the modules, both should be installed
make modules_install || exit
make install || exit

# deprecated way to make initramfs:
# genkernel --install --kerneldir=${KERNEL_PATH} --kernel-config=${KERNEL_PATH}/.config --makeopts="-j4" initramfs

# new way to generate initramfs
# needs package.use: `sys-kernel/installkernel dracut`
# check `equery uses sys-kernel/installkernel` if you upgrading from dist-bin
# NOTE: remember to change CONFIG_LOCALVERSION="-gentoo-dist-bin" from `modprobed-db`
# CONFIG_LOCALVERSION="-gentoo" should match /usr/src naming
# should run automatically after `make install`
